{{ 'form-builder-dynamic.css' | asset_url | stylesheet_tag }}
<div id="easy-form-{{ block.id }}" class="form-builder-container" data-form-id="{{ block.settings.form_id }}">
  <div class="form-loading">Loading form...</div>
</div>

<style>
  #easy-form-{{ block.id }} { width: 100% !important; max-width: 100% !important; display: block !important; pointer-events: auto !important; }
  #easy-form-{{ block.id }} form { width: 100% !important; pointer-events: auto !important; display: flex !important; flex-wrap: wrap !important; }
  #easy-form-{{ block.id }} button.submit { transition: all 0.2s ease !important; cursor: pointer !important; position: relative !important; z-index: 999 !important; }
  #easy-form-{{ block.id }} button.submit:hover { opacity: 0.9 !important; transform: translateY(-1px) !important; }
  #easy-form-{{ block.id }} small.messages.has-error,
  #easy-form-{{ block.id }} .messages.has-error { color: #f44336 !important; display: block !important; }
</style>

<script>
(function() {
  console.log('EFB: Liquid Script Initializing');
  const container = document.getElementById('easy-form-{{ block.id }}');
  const formId = '{{ block.settings.form_id }}';
  const shop = '{{ shop.permanent_domain }}';

  function notify(msg, type) {
    const n = document.createElement('div');
    Object.assign(n.style, { 
      position:'fixed', top:'20px', right:'20px', 
      background:type==='success'?'#4caf50':'#f44336', 
      color:'white', padding:'16px 24px', borderRadius:'4px', 
      boxOrigin:'border-box', boxShadow:'0 4px 12px rgba(0,0,0,0.15)', 
      zIndex:'99999', cursor:'pointer', fontFamily: 'sans-serif',
      fontSize: '14px', fontWeight: '500', transition: 'all 0.3s ease'
    });
    n.textContent = msg; document.body.appendChild(n);
    setTimeout(() => { n.style.opacity = '0'; setTimeout(() => n.remove(), 300); }, 3500);
    n.onclick = () => n.remove();
  }

  async function init() {
    if (!formId || formId === '0') return;
    const url = `/apps/easy-form-builder/render?form_id=${formId}&shop=${shop}&cb=${Date.now()}`;
    console.log('EFB: Loading form from:', url);
    try {
      const r = await fetch(url);
      const html = await r.text();
      if (html && html.includes('<form')) {
        container.innerHTML = html;
        console.log('EFB: Form HTML injected');
        attachListeners(container);
      } else {
        console.error('EFB: Invalid form HTML received');
      }
    } catch(e) { console.error('EFB: Fetch error:', e); }
  }

  function attachListeners(cont) {
    const form = cont.querySelector('form');
    if (!form) return;
    
    // Support file uploads
    form.querySelectorAll('.file_button').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        const input = btn.closest('.upload-area')?.querySelector('input[type="file"]');
        if (input) input.click();
      };
    });

    const handleSubmit = async (e) => {
      if (e) e.preventDefault();
      console.log('EFB: Submit triggered');
      
      // Clear previous error messages first
      form.querySelectorAll('.messages').forEach(el => {
          if (!el.hasAttribute('data-orig')) el.setAttribute('data-orig', el.textContent);
          el.textContent = el.getAttribute('data-orig');
          el.classList.remove('has-error');
      });

      // Custom validation — show inline errors for all required fields
      let firstErrorField = null;
      let hasError = false;
      const requiredFields = form.querySelectorAll('[required]');
      
      requiredFields.forEach(field => {
          let value = field.value;
          
          // Checkbox / Radio — check if at least one in group is selected
          if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) {
              const name = field.getAttribute('name');
              if (name) {
                  const group = form.querySelectorAll(`input[name="${name}"]:checked`);
                  if (group.length === 0) value = "";
                  else value = "checked";
              } else {
                  value = "";
              }
          }
          
          // File input — check if a file is selected
          if (field.type === 'file') {
              value = field.files && field.files.length > 0 ? 'file' : '';
          }

          // Select (dropdown / country) — empty string means nothing selected
          if (field.tagName === 'SELECT') {
              value = field.value || '';
          }
          
          if (!value || (typeof value === 'string' && value.trim() === '')) {
              hasError = true;
              const label = field.closest('.code-form-control')?.querySelector('label')?.textContent.replace('*', '').trim() || 'This field';
              const errorMessage = `${label} is required.`;
              
              // Show inline error in .messages element (red color via CSS class)
              const msgEl = field.closest('.code-form-control')?.querySelector('.messages');
              if (msgEl) {
                  msgEl.textContent = errorMessage;
                  msgEl.classList.add('has-error');
              }
              
              if (!firstErrorField) {
                  firstErrorField = field;
                  // No toast/popup — sirf inline error
              }
          }
      });
      
      if (hasError) {
          if (firstErrorField) firstErrorField.focus();
          return;
      }
      
      // Strict Validation Checks
      const emailInput = form.querySelector('input[type="email"], input[name="email"]');
      if (emailInput && emailInput.value) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[a-zA-Z]{2,20}$/;
        if (!emailRegex.test(emailInput.value)) {
          const msgEl = emailInput.closest('.code-form-control')?.querySelector('.messages');
          if (msgEl) {
              msgEl.textContent = 'Please enter a valid email address.';
              msgEl.classList.add('has-error');
          }
          emailInput.focus();
          return;
        }
      }

      const phoneInput = form.querySelector('input[type="tel"]');
      if (phoneInput && phoneInput.value) {
        if (phoneInput.value.length < 5) {
          const msgEl = phoneInput.closest('.code-form-control')?.querySelector('.messages');
          if (msgEl) {
              msgEl.textContent = 'Please enter a valid phone number.';
              msgEl.classList.add('has-error');
          }
          phoneInput.focus();
          return;
        }
      }
      
      const btn = form.querySelector('.action.submit, button[type="submit"]');
      if (btn) { 
        btn.disabled = true; 
        btn.style.opacity = '0.5'; 
        btn.dataset.orig = btn.innerHTML;
        btn.innerHTML = 'Submitting...'; 
      }
      
      try {
        const fd = new FormData(form);
        fd.append('routine_name', 'addformdata');
        if (!fd.has('store')) fd.append('store', shop);
        if (!fd.has('form_id')) fd.append('form_id', formId);
        
        const res = await fetch('/apps/easy-form-builder/ajax', { method: 'POST', body: fd });
        const data = await res.json();
        console.log('EFB: Response:', data);
        
        if (data.result === 'success') {
          // Show inline success in footer messages area
          const footerMsg = cont.querySelector('.footer .messages');
          if (footerMsg) {
              footerMsg.textContent = data.msg || 'Form submitted successfully!';
              footerMsg.style.color = '#4caf50';
              footerMsg.style.display = 'block';
          }
          form.reset();
          // Clear error styles
          form.querySelectorAll('.messages.has-error').forEach(el => el.classList.remove('has-error'));
          // Clear any file previews if they exist
          cont.querySelectorAll('.img-container').forEach(c => c.innerHTML = '');
          cont.querySelectorAll('.upload-area').forEach(a => a.classList.remove('has-files'));
        } else {
          // Show error in footer messages
          const footerMsg = cont.querySelector('.footer .messages');
          if (footerMsg) {
              footerMsg.textContent = data.msg || 'Something went wrong. Please try again.';
              footerMsg.classList.add('has-error');
          }
        }
      } catch(err) { console.error('EFB: Ajax error:', err); notify('Submission failed. Check console for details.', 'error'); }
      
      if (btn) { 
        btn.disabled = false; 
        btn.style.opacity = '1'; 
        btn.innerHTML = btn.dataset.orig || 'Submit'; 
      }
    };

    form.onsubmit = handleSubmit;
    const subBtn = form.querySelector('.action.submit, button[type="submit"]');
    if (subBtn) subBtn.onclick = handleSubmit;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "Easy Form Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "default": "0"
    }
  ]
}
{% endschema %}
