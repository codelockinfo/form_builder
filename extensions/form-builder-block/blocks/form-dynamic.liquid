{{ 'form-builder-dynamic.css' | asset_url | stylesheet_tag }}
<div id="easy-form-{{ block.id }}" class="form-builder-container" data-form-id="{{ block.settings.form_id }}">
  <div class="form-loading">Loading form...</div>
</div>

<style>
  #easy-form-{{ block.id }} { width: 100% !important; max-width: 100% !important; display: block !important; pointer-events: auto !important; }
  #easy-form-{{ block.id }} form { width: 100% !important; pointer-events: auto !important; display: flex !important; flex-wrap: wrap !important; }
  #easy-form-{{ block.id }} button.submit { transition: all 0.2s ease !important; cursor: pointer !important; position: relative !important; z-index: 999 !important; }
  #easy-form-{{ block.id }} button.submit:hover { opacity: 0.9 !important; transform: translateY(-1px) !important; }
</style>

<script>
(function() {
  console.log('EFB: Liquid Script Initializing');
  const container = document.getElementById('easy-form-{{ block.id }}');
  const formId = '{{ block.settings.form_id }}';
  const shop = '{{ shop.permanent_domain }}';

  async function init() {
    if (!formId || formId === '0') return;
    const url = `/apps/easy-form-builder/render?form_id=${formId}&shop=${shop}&cb=${Date.now()}`;
    console.log('EFB: Loading form from:', url);
    try {
      const r = await fetch(url);
      const html = await r.text();
      if (html && html.includes('<form')) {
        container.innerHTML = html;
        console.log('EFB: Form HTML injected');
        attachListeners(container);
      } else {
        console.error('EFB: Invalid form HTML received');
      }
    } catch(e) { console.error('EFB: Fetch error:', e); }
  }

  function attachListeners(cont) {
    const form = cont.querySelector('form');
    if (!form) return;
    
    // Support file uploads
    form.querySelectorAll('.file_button').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        const input = btn.closest('.upload-area')?.querySelector('input[type="file"]');
        if (input) input.click();
      };
    });

    const handleSubmit = async (e) => {
      if (e) e.preventDefault();
      console.log('EFB: Submit triggered');
      
      if (form.reportValidity && !form.reportValidity()) return;
      
      const btn = form.querySelector('.action.submit, button[type="submit"]');
      if (btn) { 
        btn.disabled = true; 
        btn.style.opacity = '0.5'; 
        btn.dataset.orig = btn.innerHTML;
        btn.innerHTML = 'Submitting...'; 
      }
      
      try {
        const fd = new FormData(form);
        fd.append('routine_name', 'addformdata');
        if (!fd.has('store')) fd.append('store', shop);
        if (!fd.has('form_id')) fd.append('form_id', formId);
        
        const res = await fetch('/apps/easy-form-builder/ajax', { method: 'POST', body: fd });
        const data = await res.json();
        console.log('EFB: Response:', data);
        
        if (data.result === 'success') {
          alert(data.msg || 'Success!');
          form.reset();
          // Clear any file previews if they exist
          cont.querySelectorAll('.img-container').forEach(c => c.innerHTML = '');
          cont.querySelectorAll('.upload-area').forEach(a => a.classList.remove('has-files'));
        } else {
          alert(data.msg || 'Error: ' + JSON.stringify(data));
        }
      } catch(err) { console.error('EFB: Ajax error:', err); alert('Submission failed. Check console for details.'); }
      
      if (btn) { 
        btn.disabled = false; 
        btn.style.opacity = '1'; 
        btn.innerHTML = btn.dataset.orig || 'Submit'; 
      }
    };

    form.onsubmit = handleSubmit;
    const subBtn = form.querySelector('.action.submit, button[type="submit"]');
    if (subBtn) subBtn.onclick = handleSubmit;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "Easy Form Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "default": "0"
    }
  ]
}
{% endschema %}
