{{ 'form-builder-dynamic.css' | asset_url | stylesheet_tag }}
<div id="easy-form-{{ block.id }}" class="form-builder-container color-{{ block.settings.color_scheme }} gradient" data-form-id="{{ block.settings.form_id }}"><div class="form-loading">Loading form...</div></div>
{%- style -%}
  #easy-form-{{ block.id }} {
    width: {{ block.settings.form_width | default: 100 }}% !important;
    display: block !important;
    {% if block.settings.form_alignment == 'center' %}
      margin-left: auto !important;
      margin-right: auto !important;
    {% elsif block.settings.form_alignment == 'right' %}
      margin-left: auto !important;
      margin-right: 0 !important;
    {% else %}
      margin-left: 0 !important;
      margin-right: auto !important;
    {% endif %}
  }
  #easy-form-{{ block.id }} form,
  #easy-form-{{ block.id }} .get_selected_elements {
    width: 100% !important;
    max-width: 100% !important;
  }
  #easy-form-{{ block.id }} .globo-heading {
    {% if block.settings.heading_color != blank and block.settings.heading_color != 'rgba(0,0,0,0)' %}
      color: {{ block.settings.heading_color }} !important;
    {% else %}
      color: {{ block.settings.color_scheme.settings.headings }} !important;
    {% endif %}
  }
  #easy-form-{{ block.id }} .globo-description,
  #easy-form-{{ block.id }} .globo-description-label {
    {% if block.settings.description_color != blank and block.settings.description_color != 'rgba(0,0,0,0)' %}
      color: {{ block.settings.description_color }} !important;
    {% else %}
      color: {{ block.settings.color_scheme.settings.text }} !important;
    {% endif %}
  }
  #easy-form-{{ block.id }} .globo-label {
    {% if block.settings.label_color != blank and block.settings.label_color != 'rgba(0,0,0,0)' %}
      color: {{ block.settings.label_color }} !important;
    {% else %}
      color: {{ block.settings.color_scheme.settings.text }} !important;
    {% endif %}
  }
  #easy-form-{{ block.id }} .globo-label,
  #easy-form-{{ block.id }} .globo-option,
  #easy-form-{{ block.id }} input,
  #easy-form-{{ block.id }} textarea,
  #easy-form-{{ block.id }} select {
    color: {{ block.settings.color_scheme.settings.text }} !important;
  }
  #easy-form-{{ block.id }} .action.submit.classic-button,
  #easy-form-{{ block.id }} .action.submit,
  #easy-form-{{ block.id }} button.submit,
  #easy-form-{{ block.id }} .submit.action,
  #easy-form-{{ block.id }} button[type="submit"] {
    background-color: {{ block.settings.color_scheme.settings.buttons | default: block.settings.color_scheme.settings.primary_button_background | default: block.settings.color_scheme.settings.accent_1 }} !important;
    background: {{ block.settings.color_scheme.settings.buttons | default: block.settings.color_scheme.settings.primary_button_background | default: block.settings.color_scheme.settings.accent_1 }} !important;
    color: {{ block.settings.color_scheme.settings.buttons_label | default: block.settings.color_scheme.settings.primary_button_text | default: '#ffffff' }} !important;
    border-color: {{ block.settings.color_scheme.settings.buttons | default: block.settings.color_scheme.settings.primary_button_background | default: block.settings.color_scheme.settings.accent_1 }} !important;
  }
  #easy-form-{{ block.id }} .action.reset.classic-button,
  #easy-form-{{ block.id }} .action.reset,
  #easy-form-{{ block.id }} button.reset,
  #easy-form-{{ block.id }} .reset.action {
    background-color: {{ block.settings.color_scheme.settings.secondary_buttons | default: 'transparent' }} !important;
    background: {{ block.settings.color_scheme.settings.secondary_buttons | default: 'transparent' }} !important;
    color: {{ block.settings.color_scheme.settings.secondary_buttons_label | default: block.settings.color_scheme.settings.text }} !important;
    border: 1px solid {{ block.settings.color_scheme.settings.secondary_buttons_label | default: block.settings.color_scheme.settings.text }} !important;
  }
{%- endstyle -%}
<script>
(function() {
  'use strict';
  function injectFormStyles() {
    if (document.getElementById('easy-form-builder-styles')) {
      return;
    }
    
    const styleElement = document.createElement('style');
    styleElement.id = 'easy-form-builder-styles';
    styleElement.textContent = ``;
    document.head.appendChild(styleElement);
  }
});
</script>

{% schema %}
{
  "name": "Easy Form Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Enter the Form ID. You can find this in your app dashboard.",
      "default": "0"
    },
    {
      "type": "select",
      "id": "form_alignment",
      "label": "Form Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ]
}
{% endschema %}