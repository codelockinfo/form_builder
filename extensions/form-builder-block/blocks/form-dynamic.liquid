<div id="easy-form-{{ block.id }}" class="form-builder-container" data-form-id="{{ block.settings.form_id }}"><div class="form-loading">Loading form...</div></div>

{{ 'form-builder-dynamic.css' | asset_url | stylesheet_tag }}
<script src="{{ 'form-builder-dynamic.js' | asset_url }}" defer="defer"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById("easy-form-{{ block.id }}");
  const formId = "{{ block.settings.form_id }}";
  const shop = "{{ shop.permanent_domain | default: shop.myshopify_domain | default: shop.domain }}";
  if (container && formId && formId !== '0' && window.EFB) {
    window.EFB.init(formId, shop, container);
  } else if (container && formId && formId !== '0') {
    const checkEFB = setInterval(() => { if (window.EFB) { window.EFB.init(formId, shop, container); clearInterval(checkEFB); } }, 100);
    setTimeout(() => clearInterval(checkEFB), 5000);
  }
});
</script>

{% schema %}
{
  "name": "Easy Form Builder",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Add a form created in the Easy Form Builder app to your page."
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Enter the Form ID of the form you created in the Easy Form Builder app.",
      "default": "0"
    }
  ]
}
{% endschema %}
